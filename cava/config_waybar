[general]
framerate = 60
bars = 10
bar_width = 1
bar_spacing = 1
sensitivity = 100
autosens = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 12000

[smoothing]
monstercat = 1
waves = 1
gravity = 90
integral = 70
noise_reduction = 0.77

[eq]
1 = 1.4
2 = 1.2
3 = 1.0
4 = 1.0
5 = 1.2

[input]
method = pipewire
source = auto

[output]
method = raw
raw_target = /dev/stdout
data_format = ascii
ascii_max_range = 7
